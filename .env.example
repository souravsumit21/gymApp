# RevenueCat (pass via --dart-define, not .env — listed here for reference)
# REVENUECAT_ANDROID_KEY=goog_your_android_key
# REVENUECAT_IOS_KEY=appl_your_ios_key

RAPIDAPI_KEY=replace_with_rapidapi_key
EXERCISEDB_HOST=exercisedb.p.rapidapi.com
EXERCISEDB_ENDPOINT=/exercises?limit=0
FIREBASE_SERVICE_ACCOUNT=./service-account.json
FIREBASE_PROJECT_ID=forge-fit-ccdde
EXERCISE_COLLECTION=exercise_library
WRITE_MEDIA_SUBCOLLECTION=false

# Video metadata seeding (scripts/seed_video_metadata_to_firestore.js)
R2_PUBLIC_BASE=https://media.reppup.app
LOCAL_VIDEOS_DIR=./exercise_videos
