# Copy to .env.local and paste your RevenueCat keys (never commit .env.local)
#
# Test Store (recommended for dev) — one key for iOS + Android:
REVENUECAT_API_KEY=test_paste_your_test_store_key_here
#
# Production platform keys (use at release):
# REVENUECAT_ANDROID_KEY=goog_...
# REVENUECAT_IOS_KEY=appl_...

# Optional — same pattern as other secrets
# ANTHROPIC_API_KEY=sk-ant-...
